{
  "info": {
    "name": "Vet01 - API Veterinaria",
    "description": "Coleccion para validar el backend de la veterinaria (CRUD de Duenos, Turnos y Mascotas).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "duenoId", "value": "" },
    { "key": "turnoId", "value": "" },
    { "key": "mascotaId", "value": "" },
    { "key": "clienteToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "portalMascotaId", "value": "" },
    { "key": "citaId", "value": "" }
  ],
  "item": [
    {
      "name": "Duenos",
      "item": [
        {
          "name": "Crear dueno",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body.id).to.be.a('number');",
                  "pm.collectionVariables.set('duenoId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/duenos", "host": ["{{baseUrl}}"], "path": ["api", "duenos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana Perez\",\n  \"contacto\": \"3001234567\",\n  \"direccion\": \"Calle 1 #2-3\",\n  \"tipoDocumento\": \"CC\",\n  \"documento\": \"10203040\"\n}"
            }
          }
        },
        {
          "name": "Listar duenos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('es arreglo', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/duenos", "host": ["{{baseUrl}}"], "path": ["api", "duenos"] }
          }
        },
        {
          "name": "Obtener dueno por id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/duenos/{{duenoId}}", "host": ["{{baseUrl}}"], "path": ["api", "duenos", "{{duenoId}}"] }
          }
        },
        {
          "name": "Actualizar dueno",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/duenos/{{duenoId}}", "host": ["{{baseUrl}}"], "path": ["api", "duenos", "{{duenoId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana Perez Actualizada\",\n  \"contacto\": \"3009999999\",\n  \"direccion\": \"Calle 1 #2-3\",\n  \"tipoDocumento\": \"CC\",\n  \"documento\": \"10203040\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Turnos",
      "item": [
        {
          "name": "Crear turno",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('turnoId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/turnos", "host": ["{{baseUrl}}"], "path": ["api", "turnos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"disponibilidad\": true,\n  \"turno\": \"Manana\",\n  \"consecutivo\": 1,\n  \"tiempoDeEspera\": 15\n}"
            }
          }
        },
        {
          "name": "Listar turnos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/turnos", "host": ["{{baseUrl}}"], "path": ["api", "turnos"] }
          }
        }
      ]
    },
    {
      "name": "Mascotas",
      "item": [
        {
          "name": "Crear mascota",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body.id).to.be.a('number');",
                  "pm.collectionVariables.set('mascotaId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/mascotas", "host": ["{{baseUrl}}"], "path": ["api", "mascotas"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Firulais\",\n  \"raza\": \"Labrador\",\n  \"anios\": 3,\n  \"servicio\": \"VACUNACION\",\n  \"duenoId\": {{duenoId}}\n}"
            }
          }
        },
        {
          "name": "Listar mascotas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/mascotas", "host": ["{{baseUrl}}"], "path": ["api", "mascotas"] }
          }
        },
        {
          "name": "Obtener mascota por id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}", "host": ["{{baseUrl}}"], "path": ["api", "mascotas", "{{mascotaId}}"] }
          }
        },
        {
          "name": "Actualizar mascota",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}", "host": ["{{baseUrl}}"], "path": ["api", "mascotas", "{{mascotaId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Firulais\",\n  \"raza\": \"Labrador\",\n  \"anios\": 4,\n  \"servicio\": \"CONSULTA_MEDICA\",\n  \"fechahoraSalida\": \"2026-06-07T10:30:00\",\n  \"duenoId\": {{duenoId}},\n  \"turnoId\": {{turnoId}}\n}"
            }
          }
        },
        {
          "name": "Eliminar mascota",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('status 204', () => pm.response.to.have.status(204));"]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/mascotas/{{mascotaId}}", "host": ["{{baseUrl}}"], "path": ["api", "mascotas", "{{mascotaId}}"] }
          }
        }
      ]
    },
    {
      "name": "Auth y portal (cliente)",
      "item": [
        {
          "name": "Registrar cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.expect(b.token).to.be.a('string');",
                  "pm.collectionVariables.set('clienteToken', b.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cliente@test.com\",\n  \"password\": \"secreto123\",\n  \"nombre\": \"Cliente Uno\",\n  \"documento\": \"CLI-001\"\n}" }
          }
        },
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('adminToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@vet.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Crear mascota (portal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('portalMascotaId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/portal/mascotas", "host": ["{{baseUrl}}"], "path": ["api", "portal", "mascotas"] },
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Toby\",\n  \"servicio\": \"CONSULTA_MEDICA\"\n}" }
          }
        },
        {
          "name": "Agendar cita (portal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('citaId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/portal/citas", "host": ["{{baseUrl}}"], "path": ["api", "portal", "citas"] },
            "body": { "mode": "raw", "raw": "{\n  \"mascotaId\": {{portalMascotaId}},\n  \"servicio\": \"CONSULTA_MEDICA\"\n}" }
          }
        },
        {
          "name": "Admin marca cita TERMINADA",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/citas/{{citaId}}/estado", "host": ["{{baseUrl}}"], "path": ["api", "citas", "{{citaId}}", "estado"] },
            "body": { "mode": "raw", "raw": "{\n  \"estado\": \"TERMINADA\"\n}" }
          }
        },
        {
          "name": "Notificaciones del cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('hay un aviso', () => pm.expect(pm.response.json().length).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/portal/notificaciones", "host": ["{{baseUrl}}"], "path": ["api", "portal", "notificaciones"] }
          }
        }
      ]
    },
    {
      "name": "Catálogo y fila",
      "item": [
        {
          "name": "Listar servicios",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('incluye URGENCIA_MEDICA', () => pm.expect(pm.response.text()).to.include('URGENCIA_MEDICA'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/servicios", "host": ["{{baseUrl}}"], "path": ["api", "servicios"] }
          }
        },
        {
          "name": "Fila de espera",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('es arreglo', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/fila", "host": ["{{baseUrl}}"], "path": ["api", "fila"] }
          }
        }
      ]
    }
  ]
}
